# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# Python tooling
__pycache__/
*.pyc
.venv/
.pytest_cache/
.mypy_cache/

# Local/private overrides (not for the public repo)
.claude.local.md
.env
BUILD_LOG.md

# CMake / build artifacts (canonical build dir is ~/.geant4_claude/build,
# outside the repo; these patterns are defensive against in-tree builds)
build/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.o
*.so
*.dylib

# Apptainer cache (normally outside the repo; defensive)
*.sif

# Demo outputs if someone runs the smoke test at the repo root.
# Leading `/` anchors to the repo root only — without it the pattern
# also matches templates/workspace/runs/, dropping the shipped
# skeleton's runs/ placeholder from the package.
/runs/
*.root
*.png

# Logs
*.log

# Geant4 source (wiki raw input — large, not tracked). No trailing slash:
# this is often a symlink into a sandbox cache, and a trailing-slash
# pattern matches directories only, so `git add -A` would otherwise stage
# a dangling absolute-path symlink.
wiki/raw/geant4-src

# Per-user Obsidian vault config (workspace state, plugins, themes)
wiki/.obsidian/

# Per-user Claude Code local state — settings.local.json, scheduled_tasks.lock,
# transcripts, etc. None of it belongs in the public repo.
.claude/

# Scratch chunked outputs from PDG-chapter ingest (regenerable from the source PDF)
wiki/raw/pdg-reviews/parts/

# superpowers brainstorm/spec/plan artifacts — process scratch, not shipped docs
docs/superpowers/
