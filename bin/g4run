#!/usr/bin/env bash
# g4run — the only bridge between geant4_claude and the Geant4/ROOT runtime.
# Every Geant4, ROOT, CMake, or g++ invocation in commands and skills must
# pass through here. Image tag and entrypoint are pinned in this file alone.

set -euo pipefail

# --- pinned runtime (single source of truth) ---------------------------------
IMAGE_TAG="ghcr.io/gemc/g4install:11.4.0-almalinux-9.4"
IMAGE_URI="docker://${IMAGE_TAG}"
ENTRYPOINT="/usr/local/bin/docker-entrypoint.sh"

# --- paths -------------------------------------------------------------------
PLUGIN_ROOT="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"

# --- helpers -----------------------------------------------------------------
log()  { printf '[g4run] %s\n' "$*" >&2; }
die()  { printf '[g4run] error: %s\n' "$*" >&2; exit 1; }

# Cache resolution: explicit env wins, else CLAUDE_PLUGIN_DATA/cache, else
# error. There is intentionally no $HOME/.geant4_claude fallback — silent
# fallback to a non-plugin path leads to phantom re-pulls when the plugin's
# own .sif already exists at $CLAUDE_PLUGIN_DATA/cache/sif/. If you're
# invoking g4run outside a Claude Code plugin context, set
# GEANT4_CLAUDE_CACHE explicitly. Resolution is lazy so `g4run help` works
# without any env vars set.
SIF_NAME="g4install_11.4.0-almalinux-9.4.sif"
CACHE_DIR=""
SIF_DIR=""
SIF_PATH=""
resolve_cache_dir() {
  [[ -n "${CACHE_DIR}" ]] && return 0
  if [[ -n "${GEANT4_CLAUDE_CACHE:-}" ]]; then
    CACHE_DIR="${GEANT4_CLAUDE_CACHE}"
  elif [[ -n "${CLAUDE_PLUGIN_DATA:-}" ]]; then
    CACHE_DIR="${CLAUDE_PLUGIN_DATA}/cache"
  else
    die "no cache path: set GEANT4_CLAUDE_CACHE or invoke from a plugin context that exports CLAUDE_PLUGIN_DATA. Slash commands should prefix every g4run call with GEANT4_CLAUDE_CACHE=\"\${CLAUDE_PLUGIN_DATA}/cache\"."
  fi
  SIF_DIR="${CACHE_DIR}/sif"
  SIF_PATH="${SIF_DIR}/${SIF_NAME}"
}

require_apptainer() {
  command -v apptainer >/dev/null 2>&1 || die "apptainer not found on PATH. Install apptainer first (https://apptainer.org)."
}

ensure_sif() {
  resolve_cache_dir
  require_apptainer
  if [[ -f "${SIF_PATH}" ]]; then return 0; fi
  mkdir -p "${SIF_DIR}"
  log "pulling ${IMAGE_URI} -> ${SIF_PATH}"
  apptainer pull "${SIF_PATH}" "${IMAGE_URI}"
}

# Resolve symlinks before handing paths to apptainer. On shared-FS hosts the
# user's $HOME or $(pwd) can be a symlink chain (e.g. ~/work -> /work/... ->
# /w/...); apptainer will --bind the symlink path but then fail to chdir to
# it inside the container. `pwd -P` and `readlink -f` give the physical
# path that apptainer can actually mount and enter.
container_workdir()   { pwd -P; }
container_cache_dir() { readlink -f "${CACHE_DIR}"; }

# --- subcommands -------------------------------------------------------------
cmd_info() {
  resolve_cache_dir
  local cache_src
  if [[ -n "${GEANT4_CLAUDE_CACHE:-}" ]]; then
    cache_src="GEANT4_CLAUDE_CACHE override"
  else
    cache_src="CLAUDE_PLUGIN_DATA (plugin default)"
  fi
  echo "image:    ${IMAGE_TAG}"
  echo "sif:      ${SIF_PATH} $([[ -f ${SIF_PATH} ]] && echo '[present]' || echo '[not pulled]')"
  echo "cache:    ${CACHE_DIR}  [${cache_src}]"
  echo "plugin:   ${PLUGIN_ROOT}"
  command -v apptainer >/dev/null 2>&1 \
    && echo "apptainer: $(apptainer --version)" \
    || echo "apptainer: NOT FOUND"
}

cmd_pull() {
  ensure_sif
  log "image ready at ${SIF_PATH}"
}

cmd_shell() {
  ensure_sif
  local wd cache_real
  wd="$(container_workdir)"
  cache_real="$(container_cache_dir)"
  log "entering container ($(basename "${SIF_PATH}")). Type 'exit' to leave."
  apptainer exec \
    --bind "${wd}" \
    --bind "${cache_real}" \
    --pwd "${wd}" \
    "${SIF_PATH}" \
    bash -lc "source ${ENTRYPOINT} && exec bash"
}

cmd_root() {
  ensure_sif
  local wd cache_real
  wd="$(container_workdir)"
  cache_real="$(container_cache_dir)"
  # The container entrypoint ends in `exec "$@"` and would otherwise clobber
  # forwarded positional args; DOCKER_ENTRYPOINT_SOURCE_ONLY=1 suppresses it.
  apptainer exec \
    --env DOCKER_ENTRYPOINT_SOURCE_ONLY=1 \
    --bind "${wd}" \
    --bind "${cache_real}" \
    --pwd "${wd}" \
    "${SIF_PATH}" \
    bash -lc 'source "$0" && root -l -b -q "$@"' "${ENTRYPOINT}" "$@"
}

# True if $1 is the directory $2 itself or a path strictly inside it.
# String-prefix matching would treat /tmp/work2 as inside /tmp/work.
path_is_under() {
  local p="$1" dir="$2"
  [[ "$p" == "$dir" || "$p" == "$dir"/* ]]
}

# Echo the host paths that need an explicit --bind beyond the workspace and
# cache. A path is auto-covered only if it is the bound workdir/cache or a
# path strictly inside one of them.
extra_binds_for() {
  local wd="$1" cache_real="$2"; shift 2
  local p
  for p in "$@"; do
    [[ -z "$p" ]] && continue
    if ! path_is_under "$p" "$wd" && ! path_is_under "$p" "$cache_real"; then
      printf -- '--bind\n%s\n' "$p"
    fi
  done
}

# Build a tiny helper binary inside the container from a source subtree
# under templates/<src_subdir>/. Caches the binary at
# ${CACHE_DIR}/bin/<helper_name>. Idempotent — only rebuilds when any
# source file is newer than the cached binary. Used by cmd_validate_gdml
# and cmd_preview to ship small Geant4-linked tools without forcing the
# user to build them from a workspace.
HELPERS_DIR=""
ensure_helper() {
  local helper_name="$1" src_subdir="$2"
  resolve_cache_dir
  HELPERS_DIR="${CACHE_DIR}/bin"
  mkdir -p "${HELPERS_DIR}"
  local helper="${HELPERS_DIR}/${helper_name}"
  local src="${PLUGIN_ROOT}/templates/${src_subdir}"
  [[ -d "${src}" ]] || die "helper source missing: ${src}"

  if [[ -x "${helper}" ]]; then
    local stale=0
    while IFS= read -r f; do
      [[ "${f}" -nt "${helper}" ]] && { stale=1; break; }
    done < <(find "${src}" -type f \( -name '*.cc' -o -name '*.hh' -o -name 'CMakeLists.txt' \))
    [[ "${stale}" -eq 0 ]] && return 0
    log "${helper_name}: source changed, rebuilding"
  fi

  ensure_sif
  local build_dir="${CACHE_DIR}/build/${helper_name}"
  rm -rf "${build_dir}"
  mkdir -p "${build_dir}"

  local wd cache_real src_real build_real
  wd="$(container_workdir)"
  cache_real="$(container_cache_dir)"
  src_real="$(readlink -f "${src}")"
  build_real="$(readlink -f "${build_dir}")"

  local -a binds=(--bind "${wd}" --bind "${cache_real}")
  while IFS= read -r line; do binds+=("${line}"); done < <(
    extra_binds_for "${wd}" "${cache_real}" "${src_real}" "${build_real}"
  )

  log "building ${helper_name} (one-time, ~30 s)…"
  apptainer exec \
    --env DOCKER_ENTRYPOINT_SOURCE_ONLY=1 \
    "${binds[@]}" \
    --pwd "${wd}" \
    "${SIF_PATH}" \
    bash -lc 'source "$0" && cmake -S "$1" -B "$2" && cmake --build "$2" -j' \
    "${ENTRYPOINT}" "${src_real}" "${build_real}"

  [[ -x "${build_real}/${helper_name}" ]] \
    || die "${helper_name} build did not produce ${build_real}/${helper_name}"
  install -Dm755 "${build_real}/${helper_name}" "${helper}"
  rm -rf "${build_real}"
  log "${helper_name} cached at ${helper}"
}

# Run a cached helper inside the container. The helper lives under
# CACHE_DIR (already bind-mounted); arg paths under wd or CACHE_DIR are
# also auto-bound. Anything else needs explicit handling.
run_helper() {
  local helper_name="$1"; shift
  resolve_cache_dir
  local helper="${CACHE_DIR}/bin/${helper_name}"
  [[ -x "${helper}" ]] || die "helper not cached: ${helper}"

  ensure_sif
  local wd cache_real helper_real
  wd="$(container_workdir)"
  cache_real="$(container_cache_dir)"
  helper_real="$(readlink -f "${helper}")"

  local -a resolved_args=()
  local -a extra_paths=()
  for arg in "$@"; do
    if [[ -e "${arg}" ]]; then
      local r; r="$(readlink -f "${arg}")"
      resolved_args+=("${r}")
      extra_paths+=("${r}")
    else
      resolved_args+=("${arg}")
    fi
  done

  local -a binds=(--bind "${wd}" --bind "${cache_real}")
  while IFS= read -r line; do binds+=("${line}"); done < <(
    extra_binds_for "${wd}" "${cache_real}" "${helper_real}" "${extra_paths[@]}"
  )

  apptainer exec \
    --env DOCKER_ENTRYPOINT_SOURCE_ONLY=1 \
    "${binds[@]}" \
    --pwd "${wd}" \
    "${SIF_PATH}" \
    bash -lc 'source "$0" && exec "$@"' \
    "${ENTRYPOINT}" "${helper_real}" "${resolved_args[@]}"
}

cmd_build() {
  local src_dir="${1:-}" build_dir="${2:-}"
  [[ -n "${src_dir}" && -n "${build_dir}" ]] \
    || die "usage: g4run build <src_dir> <build_dir>"
  [[ -d "${src_dir}" ]] || die "source dir does not exist: ${src_dir}"
  [[ -f "${src_dir}/CMakeLists.txt" ]] \
    || die "no CMakeLists.txt in ${src_dir}"
  mkdir -p "${build_dir}"

  ensure_sif
  local wd cache_real src_real build_real
  wd="$(container_workdir)"
  cache_real="$(container_cache_dir)"
  src_real="$(readlink -f "${src_dir}")"
  build_real="$(readlink -f "${build_dir}")"

  local -a binds=(--bind "${wd}" --bind "${cache_real}")
  while IFS= read -r line; do binds+=("${line}"); done < <(
    extra_binds_for "${wd}" "${cache_real}" "${src_real}" "${build_real}"
  )

  apptainer exec \
    --env DOCKER_ENTRYPOINT_SOURCE_ONLY=1 \
    "${binds[@]}" \
    --pwd "${wd}" \
    "${SIF_PATH}" \
    bash -lc 'source "$0" && cmake -S "$1" -B "$2" && cmake --build "$2" -j' \
    "${ENTRYPOINT}" "${src_real}" "${build_real}"
  log "built: ${build_real}"
}

cmd_exec() {
  local exe="${1:-}"
  [[ -n "${exe}" ]] || die "usage: g4run exec <executable> [args...]"
  shift
  local exe_real
  exe_real="$(readlink -f "${exe}" 2>/dev/null || true)"
  [[ -n "${exe_real}" && -x "${exe_real}" ]] || die "not an executable: ${exe}"

  ensure_sif
  local wd cache_real
  wd="$(container_workdir)"
  cache_real="$(container_cache_dir)"

  local -a binds=(--bind "${wd}" --bind "${cache_real}")
  while IFS= read -r line; do binds+=("${line}"); done < <(
    extra_binds_for "${wd}" "${cache_real}" "${exe_real}"
  )

  # DOCKER_ENTRYPOINT_SOURCE_ONLY=1 stops the container entrypoint from
  # exec'ing positional args, since we want them as args to our exe.
  apptainer exec \
    --env DOCKER_ENTRYPOINT_SOURCE_ONLY=1 \
    "${binds[@]}" \
    --pwd "${wd}" \
    "${SIF_PATH}" \
    bash -lc 'source "$0" && exec "$@"' \
    "${ENTRYPOINT}" "${exe_real}" "$@"
}

cmd_validate_gdml() {
  local gdml="${1:-}"
  [[ -n "${gdml}" ]] || die "usage: g4run validate-gdml <file.gdml>"
  [[ -f "${gdml}" ]] || die "no such file: ${gdml}"

  # Layer 1: XML well-formedness (xmllint, ~ms). The path is passed as a
  # positional arg, never interpolated into a shell string — a quote or
  # shell metachar in the filename would otherwise break or inject.
  ensure_sif
  local v_wd v_cache_real
  v_wd="$(container_workdir)"
  v_cache_real="$(container_cache_dir)"
  apptainer exec \
    --env DOCKER_ENTRYPOINT_SOURCE_ONLY=1 \
    --bind "${v_wd}" \
    --bind "${v_cache_real}" \
    --pwd "${v_wd}" \
    "${SIF_PATH}" \
    bash -lc 'source "$0" && xmllint --noout "$1"' "${ENTRYPOINT}" "${gdml}"

  # Layer 2: G4GDMLParser semantic check. Catches missing materials, bad
  # solid/volume refs, malformed auxiliary tags — anything xmllint misses.
  ensure_helper validate_gdml validate
  run_helper validate_gdml "${gdml}"

  log "GDML parses cleanly (xmllint + G4GDMLParser): ${gdml}"
}

cmd_preview() {
  # Two backends:
  #   sketch    (default) — host-side matplotlib projection of <solids> +
  #                         <structure>. No container, no Geant4 call. Three
  #                         orthographic PNGs (xy/yz/xz). Stdlib XML parse +
  #                         matplotlib. Fast, but does not handle boolean
  #                         solids or non-axis-aligned curved surfaces beyond
  #                         convex-hull silhouettes.
  #   raytracer (alpha)   — Geant4 RayTracer driven by a cached helper
  #                         binary. Three JPEGs (iso/xy/yz). Currently hangs
  #                         in the v11.4 container; see docs/DESIGN.md
  #                         hardening backlog. Kept opt-in for when it gets
  #                         fixed.
  local backend="sketch" gdml="" out_dir=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --backend=*)        backend="${1#--backend=}"; shift ;;
      --backend)          backend="${2:-}"; shift 2 ;;
      -h|--help)
        cat <<EOF
usage: g4run preview <file.gdml> [out_dir] [--backend=sketch|raytracer]

Default backend is 'sketch' (matplotlib, host-side, fast).
Use --backend=raytracer for the Geant4 RayTracer helper (alpha).
EOF
        return 0 ;;
      --) shift; break ;;
      -*) die "unknown flag: $1 (try --help)" ;;
      *)  if [[ -z "${gdml}" ]]; then gdml="$1"
          elif [[ -z "${out_dir}" ]]; then out_dir="$1"
          else die "extra positional arg: $1"; fi
          shift ;;
    esac
  done

  [[ -n "${gdml}" ]] || die "usage: g4run preview <file.gdml> [out_dir] [--backend=sketch|raytracer]"
  [[ -f "${gdml}" ]] || die "no such file: ${gdml}"

  if [[ -z "${out_dir}" ]]; then
    local base; base="$(basename "${gdml}" .gdml)"
    out_dir="$(dirname "${gdml}")/${base}.preview"
  fi
  mkdir -p "${out_dir}"
  local out_real; out_real="$(readlink -f "${out_dir}")"

  case "${backend}" in
    sketch)
      local py="${PLUGIN_ROOT}/scripts/preview_gdml.py"
      [[ -f "${py}" ]] || die "missing sketch backend: ${py}"
      local python_bin="python3"
      # Prefer the plugin's managed venv if it exists (the SessionStart hook
      # installs matplotlib there). Falls back to PATH python3 otherwise.
      if [[ -n "${CLAUDE_PLUGIN_DATA:-}" && -x "${CLAUDE_PLUGIN_DATA}/venv/bin/python" ]]; then
        python_bin="${CLAUDE_PLUGIN_DATA}/venv/bin/python"
      fi
      "${python_bin}" "${py}" "${gdml}" "${out_real}"
      ;;
    raytracer)
      ensure_helper preview_gdml preview
      run_helper preview_gdml "${gdml}" "${out_real}"
      ;;
    *)
      die "unknown backend: ${backend} (want: sketch | raytracer)" ;;
  esac

  log "preview images written to ${out_dir}/  [backend=${backend}]"
}

usage() {
  cat <<EOF
g4run — apptainer wrapper for geant4_claude

Usage: g4run <subcommand> [args]

Subcommands:
  pull                          Pull and cache the pinned container image.
  info                          Show image and cache status.
  shell                         Open an interactive shell inside the container.
  build <src> <build>           CMake-build the user source tree inside the container.
  exec  <executable> [args...]  Run an executable inside the container.
  root  <args...>               Run ROOT inside the container.
  validate-gdml <file>          Two-layer GDML check inside the container:
                                xmllint (XML well-formedness) plus
                                G4GDMLParser::Read (materials, refs, aux tags).
                                Builds a tiny cached helper on first use.
  preview <file.gdml> [out_dir] [--backend=sketch|raytracer]
                                Render headless previews of a GDML file.
                                sketch (default): three PNG orthographic
                                projections (xy/yz/xz) via host matplotlib —
                                fast, no Geant4 call, handles box/tube/cone/
                                polycone.  raytracer (alpha): three JPEGs
                                via Geant4's RayTracer in a cached helper
                                binary — currently hangs in v11.4 container.
                                Default out_dir is <file.gdml>.preview/.

Image: ${IMAGE_TAG}
Cache resolution order:
  1. \$GEANT4_CLAUDE_CACHE              (explicit override; required outside plugin context)
  2. \$CLAUDE_PLUGIN_DATA/cache         (auto-set when invoked via Claude Code)
Run \`g4run info\` to see the resolved cache path.
EOF
}

# --- dispatch ----------------------------------------------------------------
# Allow `source bin/g4run` in unit tests to load the functions/constants
# without running a subcommand.
if [[ "${BASH_SOURCE[0]:-}" != "${0}" ]]; then
  return 0 2>/dev/null || true
fi
sub="${1:-}"; shift || true
case "${sub}" in
  ""|-h|--help|help) usage; exit 0 ;;
esac
case "${sub}" in
  pull)           cmd_pull "$@" ;;
  info)           cmd_info "$@" ;;
  shell)          cmd_shell "$@" ;;
  build)          cmd_build "$@" ;;
  exec)           cmd_exec "$@" ;;
  root)           cmd_root "$@" ;;
  validate-gdml)  cmd_validate_gdml "$@" ;;
  preview)        cmd_preview "$@" ;;
  *)              usage; die "unknown subcommand: ${sub}" ;;
esac
